{"id": "thorlabs-det36a2", "item_name": "Biased silicon photodetector, 350-1100 nm", "description": "Reverse-biased silicon PIN photodiode detector with a 13 mm^2 active area, sensitive over the 350-1100 nm spectral range with a 14 ns rise time for measuring optical pulses and intensity. Includes universal mounting holes for post mounting in an optical setup.", "gold_eccn": "EAR99", "manufacturer": "Thorlabs", "source_url": "https://www.thorlabs.com/item/DET36A2", "source_type": "manufacturer_self_classification", "verified": false, "category": "EAR99", "difficulty": "easy", "notes": "Source quote: product data field \"eccnTL\":\"EAR99\". Published ECCN as raw text: 'EAR99'. PENDING human verification."}
